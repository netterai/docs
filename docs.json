{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Product Guide",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#1C1C23",
    "light": "#2a2a35",
    "dark": "#1C1C23"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Pipelines",
        "icon": "workflow",
        "expanded": true,
        "pages": [
          "pipelines/quickstart",
          "pipelines/step-types",
          "pipelines/operators",
          "pipelines/triggers",
          "pipelines/runs",
          "pipelines/execution-modes",
          "pipelines/monitoring"
        ]
      },
      {
        "group": "Ontology",
        "icon": "shapes",
        "expanded": true,
        "pages": [
          "ontology/overview",
          "ontology/promote-data",
          "ontology/edit-rows",
          "ontology/query"
        ]
      },
      {
        "group": "Applications",
        "icon": "layout-dashboard",
        "expanded": true,
        "pages": [
          "applications/overview",
          "applications/build",
          "applications/bindings",
          "applications/actions",
          "applications/versions"
        ]
      },
      {
        "group": "Permissions",
        "icon": "shield-check",
        "expanded": true,
        "pages": [
          "permissions/overview",
          "permissions/row-level-security"
        ]
      },
      {
        "group": "Security",
        "icon": "lock",
        "expanded": true,
        "pages": [
          "security/single-sign-on",
          "security/scim-provisioning"
        ]
      },
      {
        "group": "API",
        "icon": "code",
        "expanded": true,
        "pages": [
          "api/overview",
          "api/api-keys",
          "api/upload-file"
        ]
      },
      {
        "group": "Integrations",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "integrations/overview",
          "integrations/authentication",
          {
            "group": "Connectors",
            "icon": "blocks",
            "pages": [
              "integrations/gmail",
              "integrations/slack",
              "integrations/salesforce",
              "integrations/notion",
              "integrations/github",
              "integrations/snowflake",
              "integrations/databricks",
              "integrations/postgresql",
              "integrations/insee",
              "integrations/pappers"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
